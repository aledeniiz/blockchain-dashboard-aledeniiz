extends layout

block content
  .container
    h1 Digital Signatures
    p.text-muted
      | A digital signature proves that a message was created by the holder of a specific private key —
      | without revealing the key itself. Anyone with the public key can verify it.

    ul.nav.nav-tabs#sigTabs(role='tablist')
      li.active(role='presentation')
        a(href='#tab-sign', role='tab', data-toggle='tab')
          span.glyphicon.glyphicon-pencil
          |  Sign
      li(role='presentation')
        a(href='#tab-verify', role='tab', data-toggle='tab')
          span.glyphicon.glyphicon-ok-circle
          |  Verify

    .tab-content.sig-tab-content

      //- ── SIGN TAB ───────────────────────────────────────────────────────────
      #tab-sign.tab-pane.active(role='tabpanel')
        .well#signWell
          form.form-horizontal

            .form-group
              label.col-sm-2.control-label Message
              .col-sm-10
                textarea#signMessage.form-control(rows='4', placeholder='Type any message to sign…', spellcheck='false')

            .form-group
              label.col-sm-2.control-label Private Key
              .col-sm-10
                input#signPrivateKey.form-control(
                  type='text',
                  placeholder='decimal private key — go to Key Pairs page to generate one',
                  autocomplete='off',
                  spellcheck='false'
                )

            .form-group
              .col-sm-offset-2.col-sm-10
                .sig-process-hint
                  code SHA-256(message)
                  |  → sign hash with private key → DER-encoded signature

            .form-group
              .col-sm-offset-2.col-sm-10
                button#signButton.btn.btn-primary(type='button')
                  span.glyphicon.glyphicon-pencil
                  |  Sign

            .form-group
              label.col-sm-2.control-label Signature
              .col-sm-10
                textarea#signatureOutput.form-control.sig-output(
                  rows='3',
                  disabled,
                  placeholder='signature will appear here after signing…',
                  spellcheck='false'
                )

            .form-group
              .col-sm-offset-2.col-sm-10
                button#copyToVerify.btn.btn-default.btn-sm(type='button', style='display:none')
                  span.glyphicon.glyphicon-arrow-right
                  |  Copy to Verify tab

        .well.well-sm.sig-step-box
          strong How signing works:
          ol
            li Hash the message with SHA-256:
              code h = SHA256(message)
            li Sign the hash with your private key:
              code sig = ECDSA_sign(h, privateKey)
            li The signature proves you held the private key — without revealing it

      //- ── VERIFY TAB ─────────────────────────────────────────────────────────
      #tab-verify.tab-pane(role='tabpanel')
        .well#verifyWell
          form.form-horizontal

            .form-group
              label.col-sm-2.control-label Message
              .col-sm-10
                textarea#verifyMessage.form-control(rows='4', placeholder='Original message…', spellcheck='false')

            .form-group
              label.col-sm-2.control-label Public Key
              .col-sm-10
                input#verifyPublicKey.form-control(
                  type='text',
                  placeholder='hex public key of the signer',
                  autocomplete='off',
                  spellcheck='false'
                )

            .form-group
              label.col-sm-2.control-label Signature
              .col-sm-10
                textarea#verifySignature.form-control(rows='3', placeholder='hex-encoded DER signature…', spellcheck='false')

            .form-group
              .col-sm-offset-2.col-sm-10
                button#verifyButton.btn.btn-primary(type='button')
                  span.glyphicon.glyphicon-ok-circle
                  |  Verify

        .well.well-sm.sig-step-box
          strong How verification works:
          ol
            li Hash the message with SHA-256:
              code h = SHA256(message)
            li Verify the signature against the public key:
              code ECDSA_verify(h, signature, publicKey)
            li
              strong Result:
              | only the holder of the matching private key could have produced this signature.
            li
              em Try changing one character in the Message — the verification will fail immediately.

  script.
    var EC = elliptic.elliptic().ec;
    var ec = new EC('secp256k1');
    var keypair = ec.genKeyPair();

    function update() {
      var privHex = keypair.getPrivate('hex');
      var pubHex  = keypair.getPublic('hex');
      $('#signPrivateKey').val(bigInt(privHex, 16).toString());
      $('#verifyPublicKey').val(pubHex);
      Cookies.set('privateKey', privHex);
      Cookies.set('publicKey', pubHex);
    }

    function resetVerifyState() {
      $('#verifyWell').removeClass('well-success well-error');
    }
    function resetSignState() {
      $('#signWell').removeClass('well-success well-error');
      $('#signatureOutput').val('');
      $('#copyToVerify').hide();
    }

    $(function() {
      // Restore keys from cookies if available
      if (Cookies.get('privateKey')) {
        keypair = ec.keyFromPrivate(Cookies.get('privateKey'));
      }
      update();

      // Sync message between both tabs
      $('#signMessage').on('input', function() {
        $('#verifyMessage').val($(this).val());
        resetVerifyState();
      });
      $('#verifyMessage').on('input', function() {
        $('#signMessage').val($(this).val());
        resetVerifyState();
      });

      // Private key typed manually (decimal)
      $('#signPrivateKey').on('input', function() {
        $(this).val($(this).val().replace(/\D/g, ''));
        if (!$(this).val()) return;
        try {
          keypair = ec.keyFromPrivate(bigInt($(this).val()).toString(16));
          update();
        } catch(e) {}
        resetSignState();
      });

      $('#verifyPublicKey, #verifySignature').on('input', resetVerifyState);

      // ── Sign ──────────────────────────────────────────────────────────────
      $('#signButton').on('click', function() {
        var message = $('#signMessage').val();
        if (!message) { alert('Please enter a message to sign.'); return; }
        try {
          var binaryMessage = buffer.Buffer.from(CryptoJS.SHA256(message).toString(CryptoJS.enc.Hex));
          var sigHex = buffer.Buffer.from(keypair.sign(binaryMessage).toDER()).toString('hex');
          $('#signatureOutput').val(sigHex);
          // Auto-populate verify tab
          $('#verifyMessage').val(message);
          $('#verifyPublicKey').val(keypair.getPublic('hex'));
          $('#verifySignature').val(sigHex);
          update();
          $('#signWell').removeClass('well-error').addClass('well-success');
          $('#copyToVerify').show();
        } catch(e) {
          $('#signatureOutput').val('Error: ' + e.message);
          $('#signWell').removeClass('well-success').addClass('well-error');
          $('#copyToVerify').hide();
        }
      });

      // ── Copy to Verify tab ────────────────────────────────────────────────
      $('#copyToVerify').on('click', function() {
        $('a[href="#tab-verify"]').tab('show');
      });

      // ── Verify ────────────────────────────────────────────────────────────
      $('#verifyButton').on('click', function() {
        var message   = $('#verifyMessage').val();
        var pubKeyHex = $('#verifyPublicKey').val().trim();
        var sigHex    = $('#verifySignature').val().trim();
        if (!message || !pubKeyHex || !sigHex) {
          alert('Please fill in Message, Public Key, and Signature.');
          return;
        }
        try {
          var tmpKey        = ec.keyFromPublic(pubKeyHex, 'hex');
          var binaryMessage = buffer.Buffer.from(CryptoJS.SHA256(message).toString(CryptoJS.enc.Hex));
          if (tmpKey.verify(binaryMessage, sigHex)) {
            $('#verifyWell').removeClass('well-error').addClass('well-success');
          } else {
            $('#verifyWell').removeClass('well-success').addClass('well-error');
          }
        } catch(e) {
          $('#verifyWell').removeClass('well-success').addClass('well-error');
        }
      });
    });
