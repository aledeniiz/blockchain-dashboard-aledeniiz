          span.glyphicon.glyphicon-link
          | &nbsp; Blockchain
        a.theory-nav-link(href='/distributed')
          span.glyphicon.glyphicon-globe
          | &nbsp; Distributed

    .theory-reference
      | Reference:&nbsp;
      a(href='https://bitcoin.org/bitcoin.pdf', target='_blank')
        | S. Nakamoto, &ldquo;Bitcoin: A Peer-to-Peer Electronic Cash System&rdquo; (2008)
