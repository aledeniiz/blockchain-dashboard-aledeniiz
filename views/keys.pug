extends layout

block content
  .container
    h1 Key Pairs
    p.text-muted
      | Every participant in a blockchain network has a unique key pair.
      | The
      strong private key
      |  is your secret. The
      strong public key
      |  is your identity — your address on the network.

    .well.keys-panel
      form.form-horizontal

        .form-group
          .col-sm-offset-2.col-sm-10
            button#randomButton.btn.btn-primary(type='button')
              span.glyphicon.glyphicon-random
              |  Generate Random Key Pair

        .form-group
          label.col-sm-2.control-label Private Key
          .col-sm-10
            input#privateKey.form-control(
              type='text',
              placeholder='Enter a decimal number, or click Generate…',
              autocomplete='off',
              spellcheck='false'
            )

        .form-group
          label.col-sm-2.control-label (hex)
          .col-sm-10
            input#privateKeyHex.form-control(type='text', disabled, placeholder='hex representation…')

        .form-group
          .col-sm-offset-2.col-sm-10
            .key-derivation-arrow
              span.key-derivation-label secp256k1: Public Key = Private Key × G (one-way)
              .key-derivation-line

        .form-group
          label.col-sm-2.control-label Public Key
          .col-sm-10
            input#publicKey.form-control(type='text', disabled, placeholder='derived from private key…')

    .row.keys-explainer
      .col-sm-4
        .well.well-sm.key-info-box
          h4
            span.glyphicon.glyphicon-lock
            |  Private Key
          p
            | A random 256-bit number (1 to 2²⁵⁶).
            | Keep it
            strong secret
            | . Anyone who has it can spend your funds.
          p.text-muted Example:
            code 12345
            |  → a valid private key.
      .col-sm-4
        .well.well-sm.key-info-box.key-info-center
          h4.text-center ↓
          p.text-center
            | Elliptic curve multiplication by generator point
            code G
            br
            | on the
            strong secp256k1
            |  curve.
            br
            | Same curve used by Bitcoin and Ethereum.
          p.text-center.text-muted Fast to compute → but impossible to reverse.
      .col-sm-4
        .well.well-sm.key-info-box
          h4
            span.glyphicon.glyphicon-eye-open
            |  Public Key
          p
            | Derived from the private key — shared publicly.
            | It is your
            strong address
            |  on the blockchain.
          p.text-muted
            | 65 bytes (uncompressed), encoded in hex.
            | Starts with
            code 04
            | .

    .well.well-sm.keys-tip
      span.glyphicon.glyphicon-info-sign
      |
      strong  Keys persist across pages.
      |  Generate a key pair here, then go to
      a(href='/signatures')  Signatures
      |  to sign a message, or to
      a(href='/transaction')  Transaction
      |  to sign a payment. Your keys are saved in the browser.

  script.
    var EC = elliptic.elliptic().ec;
    var ec = new EC('secp256k1');
    var keypair = ec.genKeyPair();

    function update() {
      var privHex = keypair.getPrivate('hex');
      var pubHex  = keypair.getPublic('hex');
      $('#privateKey').val(bigInt(privHex, 16).toString());
      $('#privateKeyHex').val(privHex);
      $('#publicKey').val(pubHex);
      Cookies.set('privateKey', privHex);
      Cookies.set('publicKey', pubHex);
    }

    $(function() {
      // Restore keys from cookies if available
      if (Cookies.get('privateKey')) {
        keypair = ec.keyFromPrivate(Cookies.get('privateKey'));
      }
      update();

      // Generate random key pair
      $('#randomButton').on('click', function() {
        keypair = ec.genKeyPair();
        update();
      });

      // Update public key when user types a decimal private key
      $('#privateKey').on('input', function() {
        var val = $(this).val().replace(/\D/g, '');
        if ($(this).val() !== val) $(this).val(val);
        if (!val) return;
        try {
          keypair = ec.keyFromPrivate(bigInt(val).toString(16));
          update();
        } catch(e) {
          $('#privateKeyHex').val('invalid');
          $('#publicKey').val('');
        }
      });
    });
